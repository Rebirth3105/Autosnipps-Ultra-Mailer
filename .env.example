# GEMINI_API_KEY: Required for Ultrasnipps Intelligence API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# HUNTER_API_KEY: Required for email verification via Hunter.io API.
HUNTER_API_KEY=mock_hunter_key_123

# TWILIO: Required for SMS integration.
TWILIO_ACCOUNT_SID=ACmock_account_sid_123
TWILIO_AUTH_TOKEN=mock_auth_token_456
TWILIO_PHONE_NUMBER=+15550001234

# Mailer configuration (.env)
MAILER_HOSTNAME=mail.localhost
MAILER_STRICT_TLS=false

# Primary SMTP relay (port 25 enabled)
PRIMARY_SMTP_HOST=smtp.yourprovider.com
PRIMARY_SMTP_PORT=25
PRIMARY_SMTP_USER=username
PRIMARY_SMTP_PASS=password

# Secondary SMTP relay (fallback port 587)
SECONDARY_SMTP_HOST=smtp.yourprovider.com
SECONDARY_SMTP_PORT=587
SECONDARY_SMTP_USER=username
SECONDARY_SMTP_PASS=password

# Tertiary SMTP relay (fallback port 465)
TERTIARY_SMTP_HOST=smtp.yourprovider.com
TERTIARY_SMTP_PORT=465
TERTIARY_SMTP_USER=username
TERTIARY_SMTP_PASS=password
